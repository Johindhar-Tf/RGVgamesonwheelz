# ─────────────────────────────────────────
# RGV Games on Wheelz — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────

# Your Resend API key — get it at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The email address that receives booking notifications
OWNER_EMAIL=your@email.com

# Your production domain — used to block cross-origin requests
# Example: https://rgvgamesonwheelz.com
# Leave empty to disable origin check during local development
ALLOWED_ORIGIN=https://rgvgamesonwheelz.com
